      <tuv xml:lang="smn">
        <seg>Tilálâšvuođâ puáhtá čuávvuđ stream peht čujottâsâst: sogku.fi/live .</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Bures boahtin!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Tiervâpuáttim!</seg>
      </tuv>
    </tu>
    <tu>
