<tmx>
  <header segtype="sentence" o-tmf="OmegaT TMX" adminlang="en-US" srclang="sme" datatype="plaintext">
    <prop type="x-filename">boade_cuovvut_neahttasaddaga_samediggelaga_nuppastusa_birra.html</prop>
  </header>
  <body>
    <tu>
      <tuv xml:lang="sme">
        <seg>Boađe čuovvut neahttasáddaga sámediggelága nuppástusa birra</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Puáđi čuávvuđ nettivuolgâttâs sämitiggelaavâ nubásmitmist</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámediggi lágida neahttasáddaga sámediggelága nuppástusas disttaga geassemánu 8. beaivve 2021 dmu 18-20. Sáhtát sáddet ovddalgihtii gažaldagaid sáddaga várás.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämitigge uárnee nettivuolgâttâs sämitiggelaavâ nubásmitmist majebaargâ kesimáánu 8. peeivi 2021 tme 18-20. Tun puávtáh vuolgâttiđ muuneeld koččâmušâid vuolgâttâs várás.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Manin sámediggelága lea dárbu ođasmahttit?</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Manen lii tárbu uđâsmittiđ Sämitiggelaavâ?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Mat leat doaibmagotti guovddáš evttohusat?</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Moh láá toimâkode kuávdáš iävtuttâsah?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Man láhkai ođastus váikkuhivčče justa mu eallimii?</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Moin naalijn uđâsmittem vaiguttiččii eidu muu elimân?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Man láhkai ášši ovdána čuovvovaččat?</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Maht äšši oovdân čuávuvâžžân?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámediggeláhkadoaibmagotti lahtut, geat leat Sámedikki evttohusas nammaduvvon, vástidit sáddagis din gažaldagaide, mat gusket sámediggelága nuppástusa.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämitiggelahâtoimâkode jesâneh, kiäh láá Sämitige iävtuttâsâst nomâttum, västideh vuolgâttâsâst tii koččâmuššáid sämitiggelaavâ nubásmitmist.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sádde gažaldaga geassemánu 4. beaivve 2021 rádjai.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Vuolgât koččâmâš kesimáánu 4. peeivi 2021 räi.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Neahttasáddaga sáhttá čuovvut čujuhusas www.samediggi.fi/live</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Nettivuolgâttâs puáhtá čuávvuđ čujottâsâst www.samediggi.fi/live</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Dilálašvuođas lea tulkon.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Tilálâšvuođâst lii tulkkum.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sádde gažaldaga</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Vuolgât koččâmâš</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámediggelága nuppástusa válmmaštallan doaibmagotti smiehttamuš dehege evttohus láhkanuppástusain olggosaddui 11.5.2021.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämitiggelaavâ nubásmittem valmâštâllee toimâkode smiettâmuš ađai iävtuttâs almostui 11.5.2021.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Vuoigatvuođaministeriija ásahii doaibmagotti áigái 1.12.2020-15.5.2021.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Riehtiministeriö asâttij sämitiggelaavâ nubásmittem valmâštâllee toimâkode ááigán 1.12.2020-15.5.2021.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Vuoigatvuođaministeriija kansliijahoavda Pekka Timonen jođihan doaibmagottis ledje Sámedikki ja ráđđehusbellodagaid ovddasteaddjit.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Riehtiministeriö kansliahovdâ Pekka Timosii jođettem toimâkoddeest lijjii Sämitige já haldâttâspiäláduvâi ovdâsteijeeh.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Loga doaibmagotti smiehttamuša dás</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Luuvâ toimâkode smiettâmuš täst</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Loga lasi sámediggelága nuppástusas: https://www.samediggi.fi/saamelaiskarajalain-muutos/</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Luuvâ lase sämitiggelaavâ nubásmitmist: https://www.samediggi.fi/samitiggelaava-nubasmittem/?lang=an</seg>
      </tuv>
    </tu>
