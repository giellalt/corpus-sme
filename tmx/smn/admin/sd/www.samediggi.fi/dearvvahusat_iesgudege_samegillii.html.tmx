  <body>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sátnegirjjáš</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sänikirjáš</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Dáinna sátnegirjjážiin bovdet somás vuogi mielde ságastit sámegiela vuosttaš deaivvadeamis, árgabeaivvis ja doaluin.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Táin uccâ sänikirjáin mij halijdep povdiđ suotâs vuovvijn mieldi savâstâllâđ sämikielân vuosmuš teivâmist, argâpeeivi já juuhlijn.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Das ii leat lossa grammatihkka, dušše muhtun ávkkálaš dajaldagat.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Täst ij lah lusis kielâoppâ, peic motomeh ávháliih eđâlduvah.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>De ii leat eará go hupmagoahtit.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Te talle ij eres ko sárnuškyettiđ!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sátnegirjjáš lea ráhkaduvvon “Sámás muinna” -kampánja oktavuođas.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sänikirjááš lii rahtum “Sáámást munjin” -kampanja ohtâvuođâst.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Buorre beaivi!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Buorre beaivi!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Pyeri peivi!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Pyeri peivi!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Tiõrv!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Tiõrv!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Hyvää päivää!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Hyvää päivää!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Maht mana?</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Tiervâttâsah Suomâst sarnum sämikielân</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Dearvvahusat iešguđege sámegillii</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Anarâškielân: Pyeri jonsahpeivi!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Davvisámegillii: Buori ustibabeaivvi/ Buori ustitvuođabeaivvi!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Davvisámegillii: Buriid mihcamáraid! / Buori jonssoha!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Nuõrttsää’m: Šiõǥǥ naʹzvaanpeiʹvv!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Nuõrttsää’m: Šiõǥǥ evvanpeeiʹv!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Suomeksi: Hyvää ystävänpäivää!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Suomeksi: Hyvää juhannusta!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Davvisámegillii: Sávan buori ustibabeaivvi buohkaide!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Davvisámegillii: Buori geasi buohkaide!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Nuõrttsää’m: Tuäivtam pukid šiõǥǥ naʹzvaanpeeiʹv!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Nuõrttsää’m: Šiõǥǥ ǩieʹss pukid!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Suomeksi: Toivotan hyvää ystävänpäivää kaikille!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Suomeksi: Hyvää kesää kaikille! Anarâškielân: Šiev jiečânâsvuođâpeivi!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Davvisámegillii: Buriid mihcamáraid! / Buori jonssoha!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Davvisámegillii: Buori iehčanasvuođabeaivvi!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Nuõrttsää’m: Šiõǥǥ evvanpeeiʹv!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Nuõrttsää’m: Šiõǥǥ jiõččnažvuõttpeiʹvv!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Suomeksi: Hyvää juhannusta!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Suomeksi: Hyvää itsenäisyyspäivää!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Anarâškielân: Pyeri keesi puohháid!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Anarâškielân: Pyereh juovlah já luholâš uđđâ ihe!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Davvisámegillii : Buriid juovllaid ja lihkolaš ođđa jagi!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Davvisámegillii: Buriid juovllaid ja lihkolaš ođđa jagi!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Nuõrttsää’m: Šiõǥǥ rosttvid da leklvaž ođđ eeʹǩǩ!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Nuõrttsää’m: Šiõǥǥ rosttvid da leklvaž ođđ eeʹjj!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Suomeksi: Hyvää joulua ja onnellista uutta vuotta!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Suomeksi: Hyvää joulua ja onnellista uutta vuotta!</seg>
