        <seg>Bures boahtin davviriikkalaš sámenuoraid konferánsii!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Tiervâpuáttim ohtsâštave-eennâmlii säminuorâi konferensân!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Áigi: 26.8.2021 Suoma áigge dmu 9.00-15.00</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Äigi: 26.8.2021 Suomâ ääigi tijme 9.00-15.00</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Báiki: Zoom</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Saje: Zoom</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Konferánsa lea nuvttá ja rabas buot sámenuoraide.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Konferens lii nuuvtá já áávus puoh säminuoráid.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Mii juohkit oassálastiid bargobájiide ja viggat váldit vuhtii sávaldagaid.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Mij jyehip almottâttâm ulmuid pargopaajijd já viggâp väldiđ tuoivuid huámášumân.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Konferánssas lea simultánadulkon.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Konferensist lii simultaantulkkum.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Buot oassálastiide sáddejuvvo t-báidi, man lea plánen govvadáiddár Arsi Keva.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Puoh uásálisteid vuolgâttep kovetaaiđâr Arsi Keva hammim t-pääiđi.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Konferánssa temá lea dálkkádatrievdan.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Konferens teeman lii šoŋŋâdâhnubástus.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Árktalaš eamiálbmogat vásihit dálkkádatrievdama garrasepmosit.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Šoŋŋâdâhnubástus vaaigut korrâsumosávt arktisâš algâaalmugáid.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámenuorat leat earenoamáš fuolastuvvan dálkkádatrievdama váikkuhusain sámiid árbevirolaš ealáhusaide ja sámekultuvrii.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Säminuorah láá eromâšávt huolâst šoŋŋâdâhnubástus vaiguttâsâst sämmilij ärbivuáválâš iäláttâssáid já sämikulttuurân.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Oassin konferánssas sámenuorat hábmejit oktasaš dálkkádatrievdama vuostásaš oainnu ja plánejit dasa doaibmamálliid.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Konferens uássin säminuorah hämmejeh ohtsii šoŋŋâdâhnubástus vuástásii uáinu já vuávájeh toos toimâmaalijd.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámi parlamentáralaš ráđi vuollásaš nuoraidráđđi lágida guovtti jagi gaskkaid davviriikkalaš sámenuoraid konferánssa.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Säämi parlamentaarlii rääđi vuálásâš nuorâirääđi uárnee jyehi nube ive ohtsâštave-eennâmlii säminuorâi konferens.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Konferánsa lágiduvvo ovttasbarggus Norgga, Ruoŧa ja Suoma Sámedikkiid nuoraiddoibmiiguin.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Konferens uárnejuvvoo ohtsâšpargoost Taažâ, Ruotâ já Suomâ Sämitigij nuorâi tuáimeiguin.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
