  <body>
    <tu>
      <tuv xml:lang="sme">
        <seg>Oahpahus- ja kulturministeriija ja Sámediggi bovdejit sámeoahpahusa davviriikkalaš forumii</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Máttááttâs- já kulttuurministeriö já Sämitigge puávdejeh sämimáttááttâs tave-eennâmlii foorumân</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Suoma oahpahus- ja kulturministeriija ja Sámediggi bovdejit sámeoahpahusa davviriikkalaš forumii Sámekulturguovddáš Sajosii Anárii 1.-2.12.2021 .</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Suomâ máttááttâs- já kulttuurministeriö já Sämitigge puávdejeh sämimáttááttâs tave-eennâmlii foorumân Säämi kulttuurkuávdáš Sajosân Anarân 1.-2.12.2021 .</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámeoahpahusa davviriikkalaš ovttasbarggu ovddideapmi lea okta dain ulbmiliin, maid Suopma lea ásahan iežas Davviriikkaid ministtarráđi ságajođiheaddjebadjái.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämimáttááttâs tave-eennâmlii oovtâstpargo ovdedem lii ohtâ ulme, maid Suomâ lii asâttâm jieijâs Tave-enâmij ministerrääđi saavâjođetteijeepajan.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Forum lea okta Suoma ságajođiheaddjebaji dáhpáhusain.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Foorum lii Suomâ saavâjođetteijeepaje tábáhtus.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Foruma ulbmilat leat</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Foorum ulmen láá</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>ollislaš gova hábmen sámeoahpahusa diliin Suomas, Ruoŧas ja Norggas,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>oleskove hammim sämimáttááttâs tiileest Suomâst, Ruotâst já Taažâst,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>sámeoahpahusa rájáid rasttilteaddji ovttasbarggu nannen,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>sämimáttááttâs raajijd rastaldittee oovtâstpargo nanodem,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>ođđa ovttasbargovugiid gávdnan ja</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>uđđâlágánij oovtâstpargovuovij kavnâm já</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>bissovaš ságastallanoktavuođa huksen riikkaid oahpahuseiseválddiid, skuvlejumi ordnejeaddjiid ja sámeservodaga gaskii.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>pisováá savâstâllâmohtâvuođâ finnim staatâi máttááttâsvirgeomâhái, škovlim uárnejeijei já sämisiärváduvâi kooskâ.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Foruma temán leat</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Foorum teeman láá</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>oahpahus sámegiela eatnigiela/ vuosttaš giela ovdáneami dorvvasteaddjin Ruoŧas, Norggas ja Suomas,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>máttááttâs sämikielâ eenikielâ / vuossâmuu kielâ ovdánem máhđulâžžân tahhen Ruotâst, Taažâst já Suomâst,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>sámegielaid revitaliserema reaiddut oahpahusas, buorit doaibmamállet iešguđet riikkas,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>sämikielâi revitalisaatio kiäinuh máttááttâsâst, šiev toimâvyevih jieškote-uv staatâst,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>oahpahusa heajos ja nana mállet sámegielaid boahttevuođa geahččanguovllus,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>máttááttâs noonâ já hiäjus maalih sämikielâi puátteevuođâ uáinust,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>sámegielaid gáiddusoahpahus iešguđet riikkas,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>sämikielâi káidusmáttááttâs jieškote-uv staatâst,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>sámegielat oahpaheaddjiid skuvlen ja gelbbolašvuođa eavttut,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>sämikielâlij máttáátteijei škovlim já tohálâšvuotâvátámâšah,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>sámegielat oahppamateriálaovttasbarggu vejolašvuođat ja</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>sämikielâlii oppâmateriaaloovtâstpargo hináh já</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>sámedieđu oahpaheapmi skuvllas buohkaide.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>sämmiláid kyeskee tiätu puohháid ohtsii máttááttâsâst.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Čuozáhatjoavku Suoma, Ruoŧa ja Norgga</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Čuosâttâhjuávkku Suomâ, Ruotâ já Taažâ</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>oahpahusministeriijat, sámedikkit ja oahpahuseiseválddit,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>máttááttâsministeriöh, sämitigeh já máttááttâsvirgeomâhááh,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>oahpahusa ja skuvlejumi ordnejeaddjit,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>máttááttâs já škovlim uárnejeijeeh,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>skuvlenpolitihkalaš mearrideaddjit,</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>škovlimpooliitliih merideijeeh,</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>sámeoahpahusa ja -skuvlejumi dutkit, sihke</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>sämimáttááttâs já -škovlim totkeeh sehe</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>eará berošteaddjit.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>iärráseh, kiäh láá perustum.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Lassedieđut golggotmánu áigge – čuovo Sámedikki fierbmesiidduid www.samediggi.fi ja oahpahus- ja kulturministeriija dáhpáhuskaleanddara https://minedu.fi/tapahtumat .</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Lasetiäđuh roovvâdmáánu ääigi – čuávu Sämitige nettisiijđoid www.samediggi.fi já máttááttâs- já kulttuurministeriö tábáhtuskalender https://minedu.fi/tapahtumat .</seg>
      </tuv>
    </tu>
