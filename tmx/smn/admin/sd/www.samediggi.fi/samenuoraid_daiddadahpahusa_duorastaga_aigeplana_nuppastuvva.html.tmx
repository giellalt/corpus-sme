  <body>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámenuoraid dáiddadáhpáhusa duorastaga áigeplána nuppástuvvá</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Säminuorâi taaiđâtábáhtus tuorâstuv äigitavlu nubbáásm</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Stuorra oassálastiid meari dihte Sámenuoraid dáiddadáhpáhusa duorastaga áigeplána nuppástuvvá.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Stuorrâ uásálisteemere keežild Säminuorâi taaiđâtábáhtus tuorâstuv äigitavlu nubbáásm.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Dáhpáhus álgá dmu 9:30 ja bistá dmu 15:30 rádjai.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Tábáhtus álgá tme 9:30 já pištá tme 15:30 räi.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Prográmma ođđa áigeplána mielde lea</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Uđđâ äigitaavlu miäldásâš ohjelm lii čuávuvâš:</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>dmu 9:30 Dáhpáhus álgá</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>tme 9:30 Tábáhtus álgá</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>dmu 12–13 Boradeapmi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>tme 12–13:00 Purâdem</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>dmu 13–14:00 Dáhpáhus joatkašuvvá</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>tme 13–14:00 Tábáhtus juátkoo</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>dmu 14:15–15:00 Guosseartista, Musihkkaguovddáš</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>tme 14:15–15:00 Artistkyessi, Muusikkuávdáš</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>dmu 15:00 Bohtosiid almmustahttin</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>tme 15:00 Puátusij almostittem</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>dmu 15:30 Dáhpáhus nohká</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>tme 15:30 Tábáhtus nohá</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Dáiddadáhpáhusa sáhttá čuovvut neahta bokte .</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Taaiđâtábáhtus puáhtá keččâđ stream-vuolgâttâssân .</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sajosis sáhttá maiddái čuovvut dáhpáhusa neahta bokte, searvamis galgá almmuhit ovddalgihtii.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sajosist lii meid streamkejâttâh, moos kalga almottâttâđ muuneeld.</seg>
      </tuv>
    </tu>
