  <body>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámedikki čoahkkin 18.2. lágiduvvo gáiddusoktavuođaiguin</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämitige čuákkim 18.2. uárnejuvvoo káidusohtâvuođâiguin</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámedikki čoahkkin 1/2021 lágiduvvo 18.2.2021 dmu 10 gáiddusoktavuođaiguin.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämitige čuákkim 1/2021 uárnejuvvoo 18.2.2021 tme 10 káidusohtâvuođâiguin.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Koronadili dihte álbmot ja media sáhttet čuovvut čoahkkima dušše njuolggo sáddaga bokte čujuhusas www.samediggi.fi/live .</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Koronatile tiet kyesih já media pyehtih čuávvuđ čuákkim tuše njuolgâ vuolgâttâs peht čujottâsâst www.samediggi.fi/live .</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sáddagis lea oažžun láhkai dulkon buot golmma sámegillii ja suomagillii.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Vuolgâttâsâst lii finnimnáál tulkkum puoh kuulmâ sämikielân já suomâkielân.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sajosa parlameantasálii ii váldojuvvo álbmot báikki ala.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Saijoos parlamentsalin ep vääldi kuosijd pääihi oolâ.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Čoahkkima 1/2021 áššelistu lea dokumeantabáŋkkus.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Čuákkim 4/2020 äššilisto lii dokumentpaaŋkist.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>1 Čoahkkima álggaheapmi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>1 Čuákkim lekkâm</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>2 Čoahkkima lágalašvuohta ja mearridanváldi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>2 Čuákkim lavâlâšvuotâ já meridemváldálâšvuotâ</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>3 Beavdegirjji dárkkisteaddjiid ja jienaidrehkenastiid válljen</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>3 Pevdikirje tärhisteijei já jienârekinistei valjim</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>4 Aitosaš čoahkkináššiid gieđahallanortnega dohkkeheapmi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>4 Eidusij čuákkimaašij kieđâvuššâmoornig tuhhiittem</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>5 Stáhtaráđi evttohus duohtavuođa- ja soabadankommišuvnna lahttun (Ii-almmolaš ášši AlmmL 6 § 9 čuokkis)</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>5 Staatârääđi iävtuttâs tuotâvuotâ- já sovâdâttâmkomissio jesânin (Ij-almolâš äšši JulkL 6 § 9 saje)</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>6 Duohtavuođa- ja soabadankommišuvnna bargui várrejuvvon áigi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>6 Tuotâvuotâ- já sovâdâttâmkomissio porgâmân väridum äigi</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>7 Sámedikki muitalus stáhtaráđđái jagis 2020</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>7 Sämitige muštâlus staatârááđán ivveest 2020</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>8 Sámedikki bargoveahkapolitihkalaš prográmma 2020-2023</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>8 Sämitige pargoviehâpooliitlâš ohjelm 2020-2023</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>9 Sámedikki máksonjuolggadusa dárkkisteapmi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>9 Sämitige pälkkinjuolgâdus tärhistem</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>10 Siidda cealkámušbivdda sámeváinniid ođđasit hávdádeamis</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>10 Siida ciälkkámušpivdem sämiuámikkâsâi uđđâsist hävdidmist</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>11 Ođđa lahtuid válljen Sámi Giellagáldu anárašgiela giellajuhkosii</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>11 Uđđâ jesânij valjim Säämi Kielâkäldee anarâškielâ kielâjuáhusân</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>12 Ságajođiheaddjiid ja Sámedikki ovddastan lahtuid oppalaščilgehus</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>12 Saavâjođetteijei já Sämitige ovdâstâm jesânij kejâstâh</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>13 Eará ovdan boahtti áššit</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>13 Eres oovdân puáttee ääših</seg>
      </tuv>
    </tu>
    <tu>
