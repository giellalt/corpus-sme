  <body>
    <tu>
      <tuv xml:lang="sme">
        <seg>Čuovvovaš Sámedikki čoahkkin (2/2018) Sámekulturguovddáš Sajosis, Anáris maŋŋebárgga 19.6.2018 dmu 10 .</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Čuávuvâš Sämitige čuákkim (2/2018) tuálloo Sajosist, Anarist majebaargâ 19.6.2018 tme 10 .</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Čoahkkima sáhttá čuovvut báikki alde parlameantasáles dahje live stream bokte čujuhusas www.sogku.fi/live .</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Puávtáh čuávvuđ čuákkim pääihi alne parlamentsalist teikâ njuolgâ stream-vuolgâttâs peht čujottâsâst www.sogku.fi/live .</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Parlameantasáles tulkonrusttegat leat guldaleaddjiid anus.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Parlamentsalist tulkkumpiergâseh láá almolávt kiävtust.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sáddagis gullo čoahkkinsáles hállojuvvon giella.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Vuolgâttâsâst kulloo čuákkimsalist sarnum kielâ.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Áššelistu</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Äššilisto</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>1 Čoahkkima álggaheapmi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>1 Čuákkim lekkâm</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>2 Čoahkkima lágalašvuođa ja mearridanválddi gávnnaheapmi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>2 Čuákkim lavâlâšvuođâ já meridemváldálâšvuođâ pahudem</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>3 Beavdegirjjidárkkisteaddjiid ja jienaidrehkenastiid válljen</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>3 Pevdikirjetärhisteijei já jienârekinistei valjim</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>4 Aitosaš čoahkkináššiid gieđahallanortnega dohkkeheapmi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>4 Eidusij čuákkimaašij kieđâvuššâmoornig tuhhiittem</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>5 Ságajođiheaddjiid ja Sámedikki ovddastan lahtuid oppalašgeahčastat</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>5 Saavâjođetteijei já Sämitige ovdâsteijee jesânij kejâstâh</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>6 Sámedikki jagi 2017 ruhtadoalloloahpaheami dohkkeheapmi</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>6 Sämitige ive 2017 ruttâtuálulopâttem tuhhiittem</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>7 Evttohus sámi kulturmearreruhtan stáhta bušeahtas jagi 2020</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>7 Iävtuttâs säämi kulttuurmeriruttân staatâ budjetist ive 2020</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>8 Evttohus sámeoahpahusa ovddideami dihte ja sámegielat oahppamateriálamearreruđa sihkkarastima dihte stáhta bušeahtas jagi 2020</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>8 Iävtuttâs sämimáttááttâs oovdedmân já sämikielâlii oppâmateriaalmeriruuđâ turviimân staatâ budjetist ive 2020</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>9 Evttohus sámegielat árrabajásgeassinbálvalusaid sihkkarastima ja ovddideami dihte stáhta bušeahtas jagi 2020</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>9 Iävtuttâs sämikielâlij arâšoddâdempalvâlusâi turviimân já oovdedmân staatâ budjetist ive 2020</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>10 Evttohus sámegielat sosiála- ja dearvvasvuođabálvalusaid sihkkarastima ja ovddideami dihte stáhta bušeahtas jagi 2020</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>10 Iävtuttâs sämikielâlij sosiaal- já tiervâsvuotâpalvâlusâi turviimân já oovdedmân staatâ budjetist ive 2020</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>11 Jiekŋameara ruovdegeaidnofidnu</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>11 Jieŋâmeerâ ryevdirađehaahâ</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>12 Anu Avaskari ja Kari Kyrö váidalus várreságajođiheaddjiid bálkkámáksima guoski áššis</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>12 Anu Avaskari já Kari Kyrö väidim värisaavâjođetteijei pálkkáátmân kyeskee ääšist</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>13 Eará ovdanboahtti áššit</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>13 Eres oovdân puáttee ääših</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>14 Almmuhanáššit</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>14 Almottâsääših</seg>
      </tuv>
    </tu>
