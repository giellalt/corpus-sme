    <tu>
      <tuv xml:lang="sme">
        <seg>Sámegielaid gáiddusoahppodiimmut fállun skuvlalaččaide!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämikielâi káidusmáttááttâshaahâ fáálá sämikielâi oppâtiijmijd päikkiškovlâláid</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámegielaid gáiddusoahpahusfidnu lágida buohkaide rabas nuortalaš-, anáraš- ja davvisámegiela oahppodiimmuid neahtas.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämikielâi káidusmáttááttâshaahâ uárnee puohháid ávus nuorttâlâš, anarâš- já orjâlâškielâ oppâtiijmijd neetist.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Oahppodiimmut leat oaivvilduvvon erenomážit skuvlalaččaide.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Oppâtijmeh láá uáivildum eromâšávt škovlâláid.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Fállun leat oahppodiimmut guđege sámegielas čuovvovaččat:</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Haahâ fáálá oppâtijmijd jieškote-uv sämikielâst čuávuvávt:</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Nuortalašgiella badjeskuvlalaččaide ja logahatstudeanttaide gaskavahku 25.3., 1.4. ja 8.4. dii 10.00–10.45</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Nuorttâlâškielâ paješkovlâláid já luvâttâhuáppeid koskoho 25.3., 1.4. já 8.4. tme 10.00–10.45</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Anárašgiella 3.–6. luohkálaččaide duorastaga 26.3., 2.4. ja 9.4. dii 10.00–10.45</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Anarâškielâ 3.–6. luokaláid tuorâstuv 26.3., 2.4. já 9.4. tme 10.00–10.45</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Davvisámegiella 0–2.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Orjâlâškielâ 0–2.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>luohkálaččaide bearjadaga 27.3., 3.4. ja mánnodaga 6.4. dii 14.00–14.45</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>luokaláid vástuppeeivi 27.3., 3.4. já vuossaargâ 6.4. tme 14.00–14.45</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Oassálastinrávvagat gávdnojit dáppe .</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Uásálistemravvuuh kávnojeh täst .</seg>
