  <body>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámenuoraid dáiddadáhpáhusa bohtosat – giitosat oassálastiide</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Säminuorâi taaiđâtábáhtus puátuseh – takkâ uásálisteid</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámenuoraid dáiddadáhpáhus ordnejuvvui 14.-15.9.2022 Anáris.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Säminuorâi taaiđâtábáhtus uárnejui 14.-15.9.2022 Anarist.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Dáhpáhusas ledje mielde 17 ovdanbuktima golmma sámegielain.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Tábáhtusâst mij ooinijm 17 oovdânpyehtimid kuulmâ sierâ sämikielân.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Lágideaddjit giitet lágidemiide oassálastiid, duopmáriid ja dáhpáhusa láidesteddjiid sihke buohkaid dáhpáhussii oassálastiid.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Uárnejeijeeh kijtteh orniistâlmáid uásálisteid, tuámárijd já jođetteijeid sehe puohâid, kiäh uásálistii tábáhtusân.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Dáhpáhusas ledje golbma šlája: musihkka, dikta sihke girjjálaš barggut musihkas ja divttas.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Tábáhtusâst lijjii kulmâ šlaajâ: muusik, tivtâstem sehe kirjálâš tivtâstem já muusik.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Dáhpáhusas ledje maid golbma ahkeluohkká: vuollel 10-jahkásaččat, vuollel 16-jahkásaččat ja 16-20-jahkásaččat.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Tábáhtusâst lijjii meid kulmâ aheluoka: vuálá 10-ihásiih, vuálá 16-ihásiih já 16–20-ihásiih.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Juohke šlájas ja luohkás bálkkašuvvui duopmáriid válljen ovdanbuktimat.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Jyehi šlaajâst já rááiđust palhâšii tuámárij valjim oovdânpyehtimijd.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Váidalahtti girjjálašbargguid eat sáhtán vel julggaštit ja mii dieđihit das farggamusat.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Vaidâlitteht kirjálij tuojij puátusijd mij ep paste vala almostittiđ já tieđettep puátusijn nuuvt jotelávt ko máhđulâš.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Bálkkašuvvon ovdanbuktimiid dahkkit besset válljet sajáiduvvama mielde 50-200 euro bálkkašumi Duodji Shoppis tai Siida Shoppis.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Palhâšum oovdânpyehtimij rähteeh peesih jieijâs saje mield valjiđ 50–200 euro palhâšume Duodji Shopist tâi Siida Shopist.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Lágideaddjit leat oktavuođas bálkkašuvvon joavkkuide boahtte vahkku áigge.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Uárnejeijeeh láá ohtâvuođâst palhâšum ulmuid puáttee oho ääigi.</seg>
      </tuv>
    </tu>
    <tu>
