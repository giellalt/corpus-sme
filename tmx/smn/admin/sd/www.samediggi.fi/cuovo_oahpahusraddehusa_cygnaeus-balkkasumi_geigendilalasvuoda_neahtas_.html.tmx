  <body>
    <tu>
      <tuv xml:lang="sme">
        <seg>Čuovo Oahpahusráđđehusa Cygnaeus-bálkkašumi geigendilálašvuođa neahtas!</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Čuávu Máttááttâshaldâttâs Cygnaeus-palhâšume jyehimtilálâšvuođâ viermist!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Oahpahusráđđehus nammadii golggotmánus sámegielaid gáiddusoahpahusa pilohttaprošeavtta oktan Cygnaeus-bálkkašumi 2020 finalistan.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Máttááttâshaldâttâs nomâttij roovvâdmáánust sämikielâi káidusmáttááttâs piiloothaavâ ohtân Cygnaeus-palhâšume 2020 finalistin.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Finalisttat leat oktiibuot guhtta.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Finalisteh láá ohtsis kuttâ.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Bálkkašumi oažžu almmustahtto mánnodaga 23.11. dii 12 neahttadilálašvuođas, man sáhttá čuovvut njuolggosáttan dán liŋkkas .</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Palhâšume uážžoo almostittoo viermitilálâšvuođâst vuossaargâ 23.11. tme 12, mon puáhtá čuávvuđ njuolgist taan liiŋkâst .</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Bálkkašumi juohká Oahpahusráđđehusa váldohoavda Olli-Pekka Heinonen.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Palhâšume juáhá Máttááttâshaldâttâs uáivihovdâ Olli-Pekka Heinonen.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámegielaid gáiddusoahpahusfidnu evttohuvvo oažžut Cygnaeus-bálkkašumi (16.10)</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämikielâi káidusmáttááttâshaahâ iävtukkâssân Cygnaeus-palhâšume uážžon (16.10)</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Oahpásnuva guđa bálkkašupmefinalistii dákko (13.10. suomagillii)</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Uáppáásm kuuđâ Cygnaeus-palhâšume finalistân täst (13.10.)</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Lassedieđut:</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Lasetiäđuh:</seg>
      </tuv>
    </tu>
