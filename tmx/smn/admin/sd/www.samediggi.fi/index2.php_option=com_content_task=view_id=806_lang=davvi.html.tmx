<tmx>
  <header segtype="sentence" o-tmf="OmegaT TMX" adminlang="en-US" srclang="sme" datatype="plaintext">
    <prop type="x-filename">index2.php_option=com_content_task=view_id=806_lang=davvi.html</prop>
  </header>
  <body>
    <tu>
      <tuv xml:lang="sme">
        <seg>Leatgo beroštuvvan oahppamateriálabargguin?</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Lah-uv perustum oppâmateriaalpargoin?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Sámediggi buvttada skuvllaid várás oahppamateriálaid.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Sämitige puovtât škoovlâi várás oppâmateriaalijd.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Dán barggus dárbbašit oahppamateriálaid ráhkadeaddjiid.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Taan pargoost tarbâšep oppâmateriaalij rähteid.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Leatgo don beroštuvvan dákkár bargguin?</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Lah-uv tun perustum tágárijn pargoin?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Materiálat ráhkaduvvojit skuvlen- ja oahppamateriálalávdegotti dohkkehan buvttadanplána vuođul, muhto váldit maid vuostá buriid ideaid ja evttohusaid.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Materiaaleh ráhtojeh škovlim- já oppâmateriaallävdikode tuhhiittem puovtâdemvuávám mield, mut jis tust láá šiev iävtuttâsah já ideah te taid kannat aainâs pyehtiđ oovdân.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Juos leat beroštuvvan oahppamateriálabargguin, de váldde oktavuođa Sámedikki skuvlen- ja oahppamateriáladoaimmahahkii.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Jis lah perustum oppâmateriaalpargoin, te vääldi ohtâvuođâ Sämitige škovlim- já oppâmateriaaltoimâttâhân.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv xml:lang="sme">
        <seg>Lassedieđuid oaččut oahppamateriálačállis.</seg>
      </tuv>
      <tuv xml:lang="smn">
        <seg>Lasetiäđuid finniih oppâmateriaalčällest.</seg>
      </tuv>
    </tu>
  </body>
